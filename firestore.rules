rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/profiles/$(request.auth.uid))
        && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.is_admin == true;
    }

    match /profiles/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow create, update: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /products/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /banners/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /gallery_items/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reviews/{id} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /orders/{id} {
      allow create: if true;
      allow read: if isAdmin() || (signedIn() && resource.data.user_id == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /app_settings/{key} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
