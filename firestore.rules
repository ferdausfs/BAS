rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/profiles/$(request.auth.uid))
        && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.is_admin == true;
    }

    // Publicly-readable product/banner/gallery data (admin writes only).
    match /products/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /banners/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /gallery_items/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Profiles (owner + admin R/W) + nested wallet subcollection.
    match /profiles/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow create, update: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();

      match /wallet/{docId} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }
    }

    // Referral codes — flat public-lookup collection so non-admin users can
    // validate a code without scanning the whole /profiles collection.
    // Anyone signed-in can read; only the code owner can write their own doc.
    match /referral_codes/{code} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.resource.data.uid is string
        && request.resource.data.code == code
        && (request.resource.data.uid == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // Per-buyer referral uses (3-use cap enforcement).  Doc id = code_uid.
    match /referral_uses/{id} {
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.referralCode is string
        && id == request.resource.data.referralCode + '_' + request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Reviews: any signed-in user can post a review (auto-approved by the app);
    // require auth to cut down on anonymous spam.
    match /reviews/{id} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    // Orders: signed-in users can place orders (guest checkout from the client
    // is blocked at the rules layer — client must support anonymous-auth or
    // phone-sign-in before re-opening `allow create: if true`).
    match /orders/{id} {
      allow create: if signedIn();
      allow read: if isAdmin() || (signedIn() && (resource.data.userId == request.auth.uid || resource.data.user_id == request.auth.uid));
      allow update, delete: if isAdmin();
    }

    // App settings: public read; admin-only writes EXCEPT for the referral
    // bookkeeping keys (`referral_pending_*`, `referral_consumed_*`,
    // `referral_uses_*`) which any signed-in user may write to (for cross-device
    // referral tracking).
    match /app_settings/{key} {
      allow read: if true;
      allow write: if isAdmin()
        || (signedIn() && (
          key.matches('referral_pending_.*')
          || key.matches('referral_consumed_.*')
          || key.matches('referral_uses_.*')
        ));
    }
  }
}
