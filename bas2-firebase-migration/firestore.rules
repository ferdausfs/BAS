rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public read
    match /products/{docId} { allow read: if true; }
    match /banners/{docId} { allow read: if true; }
    match /gallery_items/{docId} { allow read: if true; }
    match /reviews/{docId} { allow read: if true; }
    match /app_settings/{docId} { allow read: if true; }

    // Authenticated write
    match /orders/{docId} {
      allow read, write: if request.auth != null;
    }
    match /reviews/{docId} {
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.user_id;
    }

    // Admin only writes (requires profiles/{uid}.is_admin == true)
    match /products/{docId} {
      allow write: if request.auth != null && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.is_admin == true;
    }
    match /banners/{docId} {
      allow write: if request.auth != null && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.is_admin == true;
    }
    match /gallery_items/{docId} {
      allow write: if request.auth != null && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.is_admin == true;
    }
    match /app_settings/{docId} {
      allow write: if request.auth != null && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.is_admin == true;
    }

    match /profiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.is_admin == true;
    }
  }
}
